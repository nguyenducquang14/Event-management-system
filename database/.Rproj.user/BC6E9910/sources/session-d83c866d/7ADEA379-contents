-- ============================================================
-- PHẦN 1: INDEXES — Tối ưu tốc độ truy vấn
-- Giảm thời gian tìm kiếm từ O(n) xuống O(log n)
-- ============================================================

-- Xóa index cũ nếu tồn tại (tránh lỗi khi chạy lại)
DROP INDEX IF EXISTS idx_events_start_time          ON Events;
DROP INDEX IF EXISTS idx_events_status              ON Events;
DROP INDEX IF EXISTS idx_events_organizer           ON Events;
DROP INDEX IF EXISTS idx_guests_email               ON Guests;
DROP INDEX IF EXISTS idx_guests_name                ON Guests;
DROP INDEX IF EXISTS idx_registrations_event_guest  ON Registrations;
DROP INDEX IF EXISTS idx_registrations_attendance   ON Registrations;
DROP INDEX IF EXISTS idx_finances_event_type        ON Finances;
DROP INDEX IF EXISTS idx_finances_date              ON Finances;
DROP INDEX IF EXISTS idx_venues_status              ON Venues;

-- ── Index 1: Tìm kiếm sự kiện theo thời gian (dùng nhiều nhất)
CREATE INDEX idx_events_start_time
    ON Events(start_time);
-- Dùng cho: SELECT ... WHERE start_time >= NOW() ORDER BY start_time

-- ── Index 2: Lọc sự kiện theo trạng thái (Draft/Scheduled/Full/Completed/Cancelled)
CREATE INDEX idx_events_status
    ON Events(status);
-- Dùng cho: WHERE status = 'Scheduled'

-- ── Index 3: Liên kết sự kiện với ban tổ chức
CREATE INDEX idx_events_organizer
    ON Events(organizer_id);
-- Dùng cho: JOIN ON organizer_id

-- ── Index 4: Tìm khách theo email (unique lookup)
CREATE INDEX idx_guests_email
    ON Guests(email);
-- Dùng cho: WHERE email = '...' — tìm kiếm O(1)

-- ── Index 5: Tìm khách theo tên (partial scan)
CREATE INDEX idx_guests_name
    ON Guests(guest_name);
-- Dùng cho: WHERE guest_name LIKE 'Nguyễn%'

-- ── Index 6: Composite index — tra cứu cặp (event_id, guest_id)
--    Tăng tốc kiểm tra đăng ký trùng và JOIN
CREATE INDEX idx_registrations_event_guest
    ON Registrations(event_id, guest_id);
-- Quan trọng: bao phủ cả 2 FK hay dùng cùng nhau

-- ── Index 7: Lọc đăng ký theo trạng thái tham dự
CREATE INDEX idx_registrations_attendance
    ON Registrations(attendance_status);
-- Dùng cho: WHERE attendance_status = 'Attended'

-- ── Index 8: Composite index tài chính — tra cứu theo sự kiện và loại
CREATE INDEX idx_finances_event_type
    ON Finances(event_id, type);
-- Dùng cho: SUM(amount) WHERE event_id=X AND type='Income'

-- ── Index 9: Lọc giao dịch tài chính theo ngày
CREATE INDEX idx_finances_date
    ON Finances(transaction_date);
-- Dùng cho: báo cáo theo kỳ

-- ── Index 10: Lọc địa điểm theo tình trạng
CREATE INDEX idx_venues_status
    ON Venues(availability_status);
-- Dùng cho: WHERE availability_status = 'Available'

