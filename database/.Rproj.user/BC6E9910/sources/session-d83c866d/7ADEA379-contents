-- ============================================================
-- PHẦN 5: TRIGGERS
-- Tự động thực thi khi có INSERT/UPDATE/DELETE
-- ============================================================

DROP TRIGGER IF EXISTS trg_check_capacity_before_register;
DROP TRIGGER IF EXISTS trg_auto_set_full_status;
DROP TRIGGER IF EXISTS trg_restore_available_on_cancel;
DROP TRIGGER IF EXISTS trg_prevent_duplicate_registration;
DROP TRIGGER IF EXISTS trg_log_checkin_timestamp;

DELIMITER $$

-- ── Trigger 1: BEFORE INSERT — Kiểm tra sức chứa TRƯỚC khi đăng ký
--    "Ăn điểm" nhất: dừng insert nếu max_capacity đã đạt
--    Demo: INSERT vào sự kiện Full → xem lỗi tự động
CREATE TRIGGER trg_check_capacity_before_register
BEFORE INSERT ON Registrations
FOR EACH ROW
BEGIN
    DECLARE v_max_cap    INT DEFAULT NULL;
    DECLARE v_current    INT DEFAULT 0;
    DECLARE v_ev_status  VARCHAR(20);

    -- Lấy max_capacity và status của sự kiện
    SELECT max_capacity, status
    INTO v_max_cap, v_ev_status
    FROM Events
    WHERE event_id = NEW.event_id;

    -- Chặn đăng ký sự kiện đã kết thúc
    IF v_ev_status IN ('Completed', 'Cancelled') THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'TRG_ERR: Không thể đăng ký sự kiện đã kết thúc/hủy.';
    END IF;

    -- Kiểm tra sức chứa (chỉ khi max_capacity được đặt)
    IF v_max_cap IS NOT NULL THEN
        SELECT COUNT(*) INTO v_current
        FROM Registrations
        WHERE event_id = NEW.event_id;

        IF v_current >= v_max_cap THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'TRG_ERR: Sự kiện đã đạt max_capacity. Đăng ký bị từ chối.';
        END IF;
    END IF;
END$$


-- ── Trigger 2: AFTER INSERT — Tự động chuyển status → 'Full'
--    Chạy SAU khi insert thành công, cập nhật trạng thái sự kiện
CREATE TRIGGER trg_auto_set_full_status
AFTER INSERT ON Registrations
FOR EACH ROW
BEGIN
    DECLARE v_max_cap INT DEFAULT NULL;
    DECLARE v_current INT DEFAULT 0;

    SELECT max_capacity INTO v_max_cap
    FROM Events WHERE event_id = NEW.event_id;

    IF v_max_cap IS NOT NULL THEN
        SELECT COUNT(*) INTO v_current
        FROM Registrations WHERE event_id = NEW.event_id;

        IF v_current >= v_max_cap THEN
            UPDATE Events
            SET status = 'Full'
            WHERE event_id = NEW.event_id
              AND status IN ('Draft', 'Scheduled');
        END IF;
    END IF;
END$$


-- ── Trigger 3: AFTER DELETE — Khôi phục trạng thái 'Scheduled' khi hủy đăng ký
--    Khi một khách hủy, nếu số đăng ký < max_capacity thì mở lại
CREATE TRIGGER trg_restore_scheduled_on_cancel
AFTER DELETE ON Registrations
FOR EACH ROW
BEGIN
    DECLARE v_max_cap INT DEFAULT NULL;
    DECLARE v_current INT DEFAULT 0;

    SELECT max_capacity INTO v_max_cap
    FROM Events WHERE event_id = OLD.event_id;

    IF v_max_cap IS NOT NULL THEN
        SELECT COUNT(*) INTO v_current
        FROM Registrations WHERE event_id = OLD.event_id;

        IF v_current < v_max_cap THEN
            UPDATE Events
            SET status = 'Scheduled'
            WHERE event_id = OLD.event_id
              AND status = 'Full';
        END IF;
    END IF;
END$$


-- ── Trigger 4: BEFORE INSERT — Ngăn đăng ký trùng lặp (defensive)
--    Dù đã có UNIQUE constraint, trigger này cung cấp thông báo rõ hơn
CREATE TRIGGER trg_prevent_duplicate_registration
BEFORE INSERT ON Registrations
FOR EACH ROW
BEGIN
    DECLARE v_exists INT DEFAULT 0;

    SELECT COUNT(*) INTO v_exists
    FROM Registrations
    WHERE event_id = NEW.event_id
      AND guest_id = NEW.guest_id;

    IF v_exists > 0 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'TRG_ERR: Khách đã đăng ký sự kiện này. Không thể đăng ký lại.';
    END IF;
END$$


-- ── Trigger 5: AFTER UPDATE — Ghi log khi check-in (thay đổi attendance_status)
--    Đảm bảo checkin_time luôn được ghi khi status → Attended
CREATE TRIGGER trg_log_checkin_timestamp
BEFORE UPDATE ON Registrations
FOR EACH ROW
BEGIN
    -- Tự động ghi thời gian check-in khi chuyển sang Attended
    IF NEW.attendance_status = 'Attended'
       AND OLD.attendance_status != 'Attended'
       AND NEW.checkin_time IS NULL
    THEN
        SET NEW.checkin_time = NOW();
    END IF;

    -- Xóa checkin_time nếu chuyển về Registered hoặc No-show
    IF NEW.attendance_status IN ('Registered', 'No-show')
       AND OLD.attendance_status = 'Attended'
    THEN
        SET NEW.checkin_time = NULL;
    END IF;
END$$

DELIMITER ;

